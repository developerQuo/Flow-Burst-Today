# =============================================================================
# 환경 변수 템플릿 - Android WebView 앱 전환용
# =============================================================================
# 이 파일을 복사하여 .env.local로 저장하고 값을 채워 사용하세요.
# 참고: .agent/instructions/android-webview-plan.md
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Admin SDK (서버 사이드 - Next.js API Routes/Server Actions)
# -----------------------------------------------------------------------------
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 비공개 키 생성
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=

# -----------------------------------------------------------------------------
# JWT 세션 관리
# -----------------------------------------------------------------------------
# 강력한 랜덤 문자열 생성: openssl rand -base64 32
JWT_SECRET=

# -----------------------------------------------------------------------------
# WebView Base URL
# -----------------------------------------------------------------------------
# 모바일 앱 WebView에서 로드할 웹앱 URL
# 동일한 세션 쿠키를 공유하려면 HTTPS 필수
WEBVIEW_BASE_URL=https://your-production-domain.com
WEBVIEW_BASE_URL_STAGING=https://your-staging-domain.com

# -----------------------------------------------------------------------------
# Google OAuth (웹 로그인용)
# -----------------------------------------------------------------------------
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# React Native 앱용 환경변수 (mobile/.env에 설정)
# =============================================================================
# 아래 변수들은 RN 앱에서 사용됩니다. 참고용으로만 적어둡니다.
# 
# GOOGLE_WEB_CLIENT_ID=     # Firebase Console에서 발급 (Web Client ID)
# GOOGLE_ANDROID_CLIENT_ID= # Firebase Console에서 발급 (Android Client ID, SHA-1 등록 필요)
# WEBVIEW_BASE_URL=         # 위와 동일
# =============================================================================
